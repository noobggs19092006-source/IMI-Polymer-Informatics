# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values for your machine.
# DO NOT commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ANSYS Installation (leave blank to let PyAEDT auto-detect)
ANSYS_VERSION=
# Windows example:  C:\Program Files\ANSYS Inc\v252\AnsysEM\ansysedt.exe
# Linux example:    /opt/ansys_inc/v252/Linux64/ansysedt
ANSYS_EXECUTABLE=

ANSYS_LICENSE_SERVER=localhost
ANSYS_LICENSE_PORT=1055

# Pipeline Settings
ANSYS_CORE_COUNT=4
ANSYS_MESH_RESOLUTION=Standard
MAX_RETRIES=3
RANDOM_SEED=42

# Directories (relative paths work; absolute paths also accepted)
WORK_DIR=./
TEMP_DIR=./temp
OUTPUT_DIR=./results
